async function getWelcome() {
  const firstName = user.name.split(' ')[0];
  const isReturn = !user.firstTime;
  const prompt = isReturn
    ? `${firstName} voltou para conversar. Faça uma saudação calorosa de retorno, lembrando que ela é ${user.type}. Seja breve e pergunte o que está no coração dela hoje.`
    : `Faça uma primeira mensagem de boas-vindas para ${firstName}, que é ${user.type} com autoridade ${user.authority} e perfil ${user.profile}.
    Compartilhe UMA revelação específica e surpreendente sobre a combinação única do tipo + perfil dela.
    Mencione brevemente a Cruz de Encarnação dela (${user.incarnationCross}) de forma acessível.
    ${user.context ? `Contexto que ela compartilhou: "${user.context}"` : ''}
    Termine perguntando qual área da vida ela quer explorar hoje. Tom: acolhedor, poético, direto.`;

  showTyping();
  const resp = await callClaude(prompt, true);
  hideTyping();
  addMsg('serena', resp);
  history.push({ role: 'assistant', content: resp });
  showChips();
  user.firstTime = false;
  localStorage.setItem(STORAGE_KEY, JSON.stringify(user));
}

// ─── MESSAGING ────────────────────────────────────────────
function autoResize(el) { el.style.height = 'auto'; el.style.height = Math.min(el.scrollHeight, 110) + 'px'; }
function handleKey(e) { if (e.key === 'Enter' && !e.shiftKey) { e.preventDefault(); sendMsg(); } }

async function sendMsg() {
  const inp = document.getElementById('msg-input');
  const text = inp.value.trim();
  if (!text || busy) return;
  inp.value = ''; inp.style.height = 'auto';
  document.getElementById('send-btn').disabled = true;
  document.getElementById('chips').innerHTML = '';
  addMsg('user', text);
  history.push({ role: 'user', content: text });
  showTyping();
  const resp = await callClaude(text, false);
  hideTyping();
  addMsg('serena', resp);
  history.push({ role: 'assistant', content: resp });
  document.getElementById('send-btn').disabled = false;
  if (history.length % 6 === 0) showChips();
}

function addMsg(role, text) {
  const container = document.getElementById('msgs');
  const wrap = document.createElement('div');
  wrap.className = `msg ${role}`;
  const av = document.createElement('div');
  av.className = 'm-avatar';
  av.textContent = role === 'serena' ? '✦' : (user.name?.[0]?.toUpperCase() || '?');
  const bub = document.createElement('div');
  bub.className = 'm-bubble';
  bub.innerHTML = text.replace(/\n/g, '<br>');
  wrap.appendChild(av); wrap.appendChild(bub);
  container.appendChild(wrap);
  container.scrollTop = container.scrollHeight;
}

function showTyping() {
  busy = true;
  const container = document.getElementById('msgs');
  const wrap = document.createElement('div');
  wrap.className = 'typing-wrap'; wrap.id = 'typing';
  const av = document.createElement('div');
  av.className = 'm-avatar';
  av.style.cssText = 'width:30px;height:30px;border-radius:50%;background:linear-gradient(135deg,#9B7D61,#DAA38F);display:flex;align-items:center;justify-content:center;font-size:.8rem;flex-shrink:0;margin-top:3px;';
  av.textContent = '✦';
  const bub = document.createElement('div');
  bub.className = 'typing-bubble';
  bub.innerHTML = '<div class="dot"></div><div class="dot"></div><div class="dot"></div>';
  wrap.appendChild(av); wrap.appendChild(bub);
  container.appendChild(wrap);
  container.scrollTop = container.scrollHeight;
}

function hideTyping() { busy = false; const t = document.getElementById('typing'); if (t) t.remove(); }

function showChips() {
  const container = document.getElementById('chips');
  container.innerHTML = '';
  const tipo = HD_KNOWLEDGE[user.type];
  const qs = tipo ? tipo.perguntas : ['Como tomar decisões melhores?', 'Como entender meu tipo?', 'Qual é minha relação com dinheiro?', 'Como usar minha energia?'];
  qs.forEach(q => {
    const chip = document.createElement('div');
    chip.className = 'chip';
    chip.textContent = q;
    chip.onclick = () => { document.getElementById('msg-input').value = q; sendMsg(); };
    container.appendChild(chip);
  });
}

// ─── CLAUDE API ───────────────────────────────────────────
