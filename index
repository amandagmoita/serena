<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Serena — Vida Autoral</title>
<link href="https://fonts.googleapis.com/css2?family=Aboreto&family=Work+Sans:ital,wght@0,200;0,300;0,400;1,300&display=swap" rel="stylesheet">
<style>
  :root {
    --milky: #9B7D61;
    --peach: #DAA38F;
    --wheat: #E9D7C0;
    --eucalyptus: #92ADA4;
    --cream: #FED8A6;
    --dark: #2C2017;
    --white: #FFFFFF;
    --glass: rgba(255,255,255,0.72);
  }
  * { margin: 0; padding: 0; box-sizing: border-box; }
  body {
    font-family: 'Work Sans', sans-serif;
    font-weight: 300;
    background: var(--wheat);
    color: var(--dark);
    min-height: 100vh;
  }
  .screen { display: none; }
  .screen.active { display: flex; }

  /* LOADING */
  #screen-loading {
    position: fixed; inset: 0; z-index: 200;
    flex-direction: column;
    align-items: center; justify-content: center;
    background: linear-gradient(160deg, var(--wheat), var(--cream) 60%, var(--peach));
  }
  .orb {
    width: 72px; height: 72px;
    background: linear-gradient(135deg, var(--milky), var(--peach), var(--eucalyptus));
    border-radius: 50%;
    margin-bottom: 2rem;
    animation: orbPulse 2s ease infinite;
  }
  .loading-label {
    font-family: 'Aboreto', cursive;
    font-size: 0.78rem;
    letter-spacing: 0.25em;
    color: var(--milky);
    animation: breathe 2s ease infinite;
  }
  .loading-sub {
    font-size: 0.72rem;
    color: rgba(44,32,23,0.45);
    margin-top: 0.6rem;
    text-align: center;
    max-width: 260px;
    line-height: 1.6;
  }

  /* ONBOARDING */
  #screen-onboarding {
    min-height: 100vh;
    flex-direction: column;
    align-items: center;
    justify-content: flex-start;
    padding: 2.5rem 1.25rem 3rem;
    background: linear-gradient(160deg, var(--wheat) 0%, var(--cream) 55%, rgba(218,163,143,0.4) 100%);
    overflow-y: auto;
    position: relative;
  }
  #screen-onboarding::before {
    content: '';
    position: fixed;
    width: 500px; height: 500px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(155,125,97,0.1) 0%, transparent 70%);
    top: -150px; right: -150px;
    pointer-events: none;
  }
  .logo-wrap {
    text-align: center;
    margin-bottom: 2rem;
    animation: fadeUp 0.7s ease both;
  }
  .triangle-logo { width: 36px; height: 36px; margin: 0 auto 0.75rem; }
  .brand-tag {
    font-family: 'Aboreto', cursive;
    font-size: 0.65rem;
    letter-spacing: 0.35em;
    color: var(--milky);
    opacity: 0.7;
  }
  .card {
    background: var(--glass);
    backdrop-filter: blur(24px);
    border-radius: 24px;
    padding: 2.5rem 2rem;
    max-width: 500px;
    width: 100%;
    border: 1px solid rgba(155,125,97,0.14);
    box-shadow: 0 20px 60px rgba(44,32,23,0.07);
    animation: fadeUp 0.7s ease 0.15s both;
    position: relative; z-index: 1;
  }
  .card-icon {
    width: 64px; height: 64px;
    background: linear-gradient(135deg, var(--milky), var(--peach));
    border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    font-size: 1.6rem;
    margin: 0 auto 1.25rem;
    box-shadow: 0 6px 20px rgba(155,125,97,0.28);
  }
  .card h2 {
    font-family: 'Aboreto', cursive;
    font-size: 1.6rem;
    color: var(--milky);
    text-align: center;
    margin-bottom: 0.5rem;
    letter-spacing: 0.04em;
  }
  .card .subtitle {
    font-size: 0.88rem;
    color: rgba(44,32,23,0.55);
    text-align: center;
    line-height: 1.7;
    margin-bottom: 2rem;
  }
  .field { margin-bottom: 1.1rem; }
  .field label {
    display: block;
    font-size: 0.7rem;
    letter-spacing: 0.13em;
    text-transform: uppercase;
    color: var(--milky);
    font-weight: 400;
    margin-bottom: 0.45rem;
  }
  .field input, .field textarea {
    width: 100%;
    padding: 0.8rem 1rem;
    border: 1.5px solid rgba(155,125,97,0.18);
    border-radius: 12px;
    background: rgba(255,255,255,0.75);
    font-family: 'Work Sans', sans-serif;
    font-weight: 300;
    font-size: 0.9rem;
    color: var(--dark);
    outline: none;
    transition: all 0.22s;
    appearance: none;
    -webkit-appearance: none;
  }
  .field input:focus, .field textarea:focus {
    border-color: var(--milky);
    background: white;
    box-shadow: 0 0 0 3px rgba(155,125,97,0.09);
  }
  .field textarea { resize: none; height: 80px; }
  .row-2 { display: grid; grid-template-columns: 1fr 1fr; gap: 0.75rem; }

  /* City autocomplete */
  .city-wrap { position: relative; }
  .city-suggestions {
    position: absolute;
    top: 100%; left: 0; right: 0;
    background: white;
    border: 1.5px solid rgba(155,125,97,0.18);
    border-top: none;
    border-radius: 0 0 12px 12px;
    max-height: 200px;
    overflow-y: auto;
    z-index: 50;
    display: none;
    box-shadow: 0 8px 24px rgba(44,32,23,0.1);
  }
  .city-suggestions.open { display: block; }
  .city-option {
    padding: 0.65rem 1rem;
    font-size: 0.82rem;
    color: var(--dark);
    cursor: pointer;
    transition: background 0.15s;
    font-family: 'Work Sans', sans-serif;
    font-weight: 300;
    border-bottom: 1px solid rgba(155,125,97,0.06);
  }
  .city-option:hover { background: rgba(155,125,97,0.06); }
  .city-option:last-child { border-bottom: none; }
  .city-option .co-region { font-size: 0.7rem; color: rgba(44,32,23,0.4); margin-top: 0.1rem; }

  .error-banner {
    background: rgba(218,163,143,0.2);
    border: 1.5px solid var(--peach);
    border-radius: 12px;
    padding: 0.75rem 1rem;
    margin-bottom: 1.1rem;
    font-size: 0.82rem;
    color: var(--dark);
    line-height: 1.5;
    display: none;
  }
  .error-banner.visible { display: block; animation: fadeUp 0.3s ease; }

  .btn {
    width: 100%;
    padding: 0.95rem;
    border: none;
    border-radius: 12px;
    font-family: 'Aboreto', cursive;
    font-size: 0.8rem;
    letter-spacing: 0.18em;
    cursor: pointer;
    transition: all 0.28s;
    margin-top: 0.25rem;
  }
  .btn-primary {
    background: linear-gradient(135deg, var(--milky), var(--peach));
    color: white;
    box-shadow: 0 4px 18px rgba(155,125,97,0.28);
  }
  .btn-primary:hover { transform: translateY(-2px); box-shadow: 0 8px 24px rgba(155,125,97,0.38); }
  .btn-primary:disabled { opacity: 0.55; cursor: not-allowed; transform: none; }
  .note {
    font-size: 0.72rem;
    color: rgba(44,32,23,0.38);
    text-align: center;
    margin-top: 1.1rem;
    line-height: 1.6;
  }

  /* CHAT */
  #screen-chat {
    flex-direction: column;
    height: 100vh;
    background: linear-gradient(180deg, var(--wheat) 0%, rgba(233,215,192,0.6) 100%);
  }
  .chat-header {
    display: flex; align-items: center; gap: 0.9rem;
    padding: 0.9rem 1.25rem;
    background: rgba(255,255,255,0.82);
    backdrop-filter: blur(20px);
    border-bottom: 1px solid rgba(155,125,97,0.1);
    position: sticky; top: 0; z-index: 10;
  }
  .h-avatar {
    width: 42px; height: 42px;
    background: linear-gradient(135deg, var(--milky), var(--peach));
    border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    font-size: 1.1rem; flex-shrink: 0;
    box-shadow: 0 3px 12px rgba(155,125,97,0.25);
  }
  .h-info { flex: 1; min-width: 0; }
  .h-name { font-family: 'Aboreto', cursive; font-size: 0.95rem; color: var(--milky); letter-spacing: 0.04em; }
  .h-type { font-size: 0.7rem; color: rgba(44,32,23,0.45); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  .h-menu-btn {
    background: none; border: none; cursor: pointer;
    color: rgba(44,32,23,0.35); font-size: 1.1rem; padding: 0.25rem;
    transition: color 0.2s;
  }
  .h-menu-btn:hover { color: var(--milky); }

  #profile-panel {
    display: none;
    background: rgba(255,255,255,0.95);
    border-bottom: 1px solid rgba(155,125,97,0.12);
    padding: 1rem 1.25rem;
    animation: fadeDown 0.25s ease;
  }
  .profile-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 0.5rem; }
  .profile-item { background: var(--wheat); border-radius: 10px; padding: 0.6rem 0.75rem; text-align: center; }
  .profile-item .pi-label { font-size: 0.6rem; letter-spacing: 0.1em; text-transform: uppercase; color: rgba(44,32,23,0.4); margin-bottom: 0.2rem; }
  .profile-item .pi-value { font-size: 0.82rem; font-weight: 400; color: var(--dark); }
  .edit-link { display: block; text-align: center; font-size: 0.72rem; color: var(--milky); margin-top: 0.75rem; cursor: pointer; text-decoration: underline; text-decoration-color: rgba(155,125,97,0.3); }

  .msgs {
    flex: 1; overflow-y: auto; padding: 1.25rem;
    display: flex; flex-direction: column; gap: 0.875rem; scroll-behavior: smooth;
  }
  .msgs::-webkit-scrollbar { width: 3px; }
  .msgs::-webkit-scrollbar-thumb { background: rgba(155,125,97,0.2); border-radius: 2px; }
  .msg { display: flex; gap: 0.65rem; animation: fadeUp 0.28s ease both; max-width: 86%; }
  .msg.user { align-self: flex-end; flex-direction: row-reverse; }
  .msg.serena { align-self: flex-start; }
  .m-avatar { width: 30px; height: 30px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 0.8rem; flex-shrink: 0; margin-top: 3px; }
  .msg.serena .m-avatar { background: linear-gradient(135deg, var(--milky), var(--peach)); }
  .msg.user .m-avatar { background: var(--eucalyptus); color: white; font-size: 0.75rem; font-weight: 400; }
  .m-bubble { padding: 0.8rem 1.05rem; border-radius: 18px; font-size: 0.875rem; line-height: 1.68; }
  .msg.serena .m-bubble { background: white; color: var(--dark); border-bottom-left-radius: 4px; box-shadow: 0 2px 14px rgba(44,32,23,0.05); }
  .msg.user .m-bubble { background: linear-gradient(135deg, var(--milky) 0%, #7a6249 100%); color: white; border-bottom-right-radius: 4px; }

  .typing-wrap { display: flex; gap: 0.65rem; align-self: flex-start; animation: fadeUp 0.28s ease both; }
  .typing-bubble { display: flex; align-items: center; gap: 4px; padding: 0.8rem 1.05rem; background: white; border-radius: 18px; border-bottom-left-radius: 4px; box-shadow: 0 2px 14px rgba(44,32,23,0.05); }
  .dot { width: 6px; height: 6px; background: var(--peach); border-radius: 50%; animation: bounce 1.2s ease infinite; }
  .dot:nth-child(2) { animation-delay: 0.18s; }
  .dot:nth-child(3) { animation-delay: 0.36s; }

  .chips-wrap { padding: 0.5rem 1.25rem; display: flex; gap: 0.45rem; overflow-x: auto; scroll-behavior: smooth; }
  .chips-wrap::-webkit-scrollbar { display: none; }
  .chip {
    white-space: nowrap; padding: 0.45rem 0.95rem;
    background: rgba(255,255,255,0.8); border: 1.5px solid rgba(155,125,97,0.18);
    border-radius: 20px; font-size: 0.75rem; color: var(--milky);
    cursor: pointer; transition: all 0.2s; font-family: 'Work Sans', sans-serif; font-weight: 300;
  }
  .chip:hover { background: var(--milky); color: white; border-color: var(--milky); }

  .input-bar { padding: 0.75rem 1.25rem 1.25rem; background: rgba(255,255,255,0.65); backdrop-filter: blur(12px); border-top: 1px solid rgba(155,125,97,0.08); }
  .input-wrap {
    display: flex; gap: 0.65rem; align-items: flex-end;
    background: white; border-radius: 16px;
    padding: 0.45rem 0.45rem 0.45rem 1rem;
    border: 1.5px solid rgba(155,125,97,0.18);
    transition: border-color 0.22s;
    box-shadow: 0 2px 14px rgba(44,32,23,0.04);
  }
  .input-wrap:focus-within { border-color: var(--milky); }
  #msg-input {
    flex: 1; border: none; outline: none;
    font-family: 'Work Sans', sans-serif; font-weight: 300; font-size: 0.875rem;
    color: var(--dark); background: transparent;
    resize: none; min-height: 22px; max-height: 110px; line-height: 1.55; padding: 0.2rem 0;
  }
  #msg-input::placeholder { color: rgba(44,32,23,0.3); }
  .send {
    width: 36px; height: 36px;
    background: linear-gradient(135deg, var(--milky), var(--peach));
    border: none; border-radius: 10px; cursor: pointer;
    display: flex; align-items: center; justify-content: center;
    transition: all 0.2s; flex-shrink: 0;
  }
  .send:hover { transform: scale(1.06); }
  .send:disabled { opacity: 0.45; cursor: not-allowed; transform: none; }
  .send svg { width: 15px; height: 15px; fill: white; }

  @keyframes fadeUp { from { opacity: 0; transform: translateY(14px); } to { opacity: 1; transform: translateY(0); } }
  @keyframes fadeDown { from { opacity: 0; transform: translateY(-8px); } to { opacity: 1; transform: translateY(0); } }
  @keyframes orbPulse { 0%, 100% { transform: scale(1); box-shadow: 0 0 0 0 rgba(155,125,97,0.3); } 50% { transform: scale(1.06); box-shadow: 0 0 0 18px rgba(155,125,97,0); } }
  @keyframes breathe { 0%, 100% { opacity: 1; } 50% { opacity: 0.45; } }
  @keyframes bounce { 0%, 60%, 100% { transform: translateY(0); } 30% { transform: translateY(-5px); } }

  @media (max-width: 420px) {
    .card { padding: 2rem 1.4rem; border-radius: 20px; }
    .card h2 { font-size: 1.35rem; }
    .row-2 { grid-template-columns: 1fr; }
    .profile-grid { grid-template-columns: 1fr 1fr; }
  }
</style>
</head>
<body>

<div id="screen-loading" class="screen active">
  <div class="orb"></div>
  <p class="loading-label" id="loading-label">Iniciando...</p>
  <p class="loading-sub" id="loading-sub"></p>
</div>

<div id="screen-onboarding" class="screen">
  <div class="logo-wrap">
    <svg class="triangle-logo" viewBox="0 0 36 36" fill="none"><path d="M18 33L3 7h30z" stroke="#9B7D61" stroke-width="1.4" fill="none"/></svg>
    <div class="brand-tag">Vida Autoral</div>
  </div>
  <div class="card">
    <div class="card-icon">✦</div>
    <h2>Bem-vinda, eu sou Serena</h2>
    <p class="subtitle">Sua guia de autoconhecimento baseada no seu Desenho Humano. Com seus dados de nascimento, vou acessar seu mapa energético completo.</p>
    <div id="error-banner" class="error-banner"></div>
    <div class="field">
      <label>Como prefere ser chamada?</label>
      <input type="text" id="f-name" placeholder="Seu nome" autocomplete="given-name">
    </div>
    <div class="row-2">
      <div class="field">
        <label>Data de nascimento</label>
        <input type="date" id="f-date">
      </div>
      <div class="field">
        <label>Hora de nascimento</label>
        <input type="time" id="f-time" value="12:00">
      </div>
    </div>
    <div class="field city-wrap">
      <label>Cidade de nascimento</label>
      <input type="text" id="f-city" placeholder="Digite o nome da cidade..." autocomplete="off" oninput="searchCity(this.value)">
      <div class="city-suggestions" id="city-suggestions"></div>
      <input type="hidden" id="f-timezone" value="">
    </div>
    <div class="field">
      <label>Algo que Serena deva saber sobre você? (opcional)</label>
      <textarea id="f-context" placeholder="Ex: estou passando por uma transição de carreira, quero entender meus relacionamentos..."></textarea>
    </div>
    <button class="btn btn-primary" id="btn-start" onclick="startSession()">Revelar meu mapa ✦</button>
    <p class="note">Seus dados ficam salvos no seu dispositivo e são usados apenas para gerar seu mapa de Desenho Humano.</p>
  </div>
</div>

<div id="screen-chat" class="screen">
  <div class="chat-header">
    <div class="h-avatar">✦</div>
    <div class="h-info">
      <div class="h-name">Serena</div>
      <div class="h-type" id="h-type-label">Guia de Autoconhecimento</div>
    </div>
    <button class="h-menu-btn" onclick="toggleProfile()" title="Ver seu perfil">⊙</button>
  </div>
  <div id="profile-panel">
    <div class="profile-grid" id="profile-grid"></div>
    <span class="edit-link" onclick="editProfile()">Recalcular meu mapa →</span>
  </div>
  <div class="msgs" id="msgs"></div>
  <div class="chips-wrap" id="chips"></div>
  <div class="input-bar">
    <div class="input-wrap">
      <textarea id="msg-input" placeholder="Pergunte algo para a Serena..." rows="1" onkeydown="handleKey(event)" oninput="autoResize(this)"></textarea>
      <button class="send" onclick="sendMsg()" id="send-btn">
        <svg viewBox="0 0 24 24"><path d="M2.01 21L23 12 2.01 3 2 10l15 2-15 2z"/></svg>
      </button>
    </div>
  </div>
</div>

