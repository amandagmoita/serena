Responda em português brasileiro. Parágrafos curtos. Máximo 220 palavras.`;
}

async function callClaude(userMsg, isWelcome) {
  try {
    let messages;
    if (isWelcome) {
      messages = [{ role: 'user', content: userMsg }];
    } else {
      messages = history.length > 1 ? history.slice(-(Math.min(history.length, 20))) : [{ role: 'user', content: userMsg }];
    }
    const res = await fetch('https://api.anthropic.com/v1/messages', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ model: 'claude-sonnet-4-20250514', max_tokens: 1000, system: buildSystem(), messages })
    });
    const data = await res.json();
    if (data.content?.[0]?.text) return data.content[0].text;
    return 'Hmm, algo não fluiu bem agora. Tente novamente em instantes.';
  } catch(e) {
    console.error(e);
    return 'Não consegui me conectar agora. Verifique sua conexão e tente novamente.';
  }
}
