// ─── INIT ─────────────────────────────────────────────────
window.addEventListener('DOMContentLoaded', () => {
  const saved = localStorage.getItem(STORAGE_KEY);
  if (saved) {
    try {
      const parsed = JSON.parse(saved);
      if (parsed.name && parsed.hdData) {
        user = parsed;
        hdData = parsed.hdData;
        showLoading('Bem-vinda de volta, ' + user.name.split(' ')[0] + '...', '', 1800, initChat);
        return;
      }
    } catch(e) {}
  }
  showLoading('Iniciando...', '', 1000, () => showScreen('screen-onboarding'));
});

document.addEventListener('click', (e) => {
  if (!e.target.closest('.city-wrap')) {
    document.getElementById('city-suggestions').classList.remove('open');
  }
});

// ─── NAVIGATION ───────────────────────────────────────────
function showLoading(label, sub, duration, callback) {
  document.getElementById('loading-label').textContent = label;
  document.getElementById('loading-sub').textContent = sub || '';
  showScreen('screen-loading');
  setTimeout(callback, duration);
}

function showScreen(id) {
  document.querySelectorAll('.screen').forEach(s => s.classList.remove('active'));
  document.getElementById(id).classList.add('active');
  window.scrollTo(0, 0);
}

function showError(msg) {
  const el = document.getElementById('error-banner');
  el.textContent = msg;
  el.classList.add('visible');
}

function hideError() {
  document.getElementById('error-banner').classList.remove('visible');
}

// ─── CITY AUTOCOMPLETE ───────────────────────────────────
function searchCity(query) {
  clearTimeout(citySearchTimeout);
  const suggestions = document.getElementById('city-suggestions');
  if (query.length < 3) { suggestions.classList.remove('open'); return; }

  citySearchTimeout = setTimeout(async () => {
    try {
      const res = await fetch(`${BG_API}/v210502/locations?api_key=${BG_KEY}&query=${encodeURIComponent(query)}`);
      const data = await res.json();
      if (!data || data.length === 0) {
        suggestions.innerHTML = '<div class="city-option" style="color:rgba(44,32,23,0.4);cursor:default">Nenhuma cidade encontrada</div>';
        suggestions.classList.add('open');
        return;
      }
      suggestions.innerHTML = data.slice(0, 8).map(loc => {
        const safeValue = loc.value.replace(/'/g, "\\'");
        return `<div class="city-option" onclick="selectCity('${safeValue}', '${loc.timezone}')">
          <div>${loc.asciiname}</div>
          <div class="co-region">${loc.admin1 ? loc.admin1 + ', ' : ''}${loc.country}</div>
        </div>`;
      }).join('');
      suggestions.classList.add('open');
    } catch(e) { console.error('City search error:', e); }
  }, 350);
}

function selectCity(value, timezone) {
  document.getElementById('f-city').value = value;
  document.getElementById('f-timezone').value = timezone;
  selectedTimezone = timezone;
  document.getElementById('city-suggestions').classList.remove('open');
}

// ─── START SESSION ────────────────────────────────────────
async function startSession() {
  hideError();
  const name = document.getElementById('f-name').value.trim();
  const date = document.getElementById('f-date').value;
  const time = document.getElementById('f-time').value || '12:00';
  const city = document.getElementById('f-city').value.trim();
  const timezone = document.getElementById('f-timezone').value;

  if (!name) { showError('Como posso te chamar? Preencha seu nome.'); return; }
  if (!date) { showError('Preciso da sua data de nascimento para acessar seu mapa.'); return; }
  if (!city || !timezone) { showError('Selecione sua cidade de nascimento na lista para que eu identifique o fuso horário correto.'); return; }

  const btn = document.getElementById('btn-start');
  btn.disabled = true;
  btn.textContent = 'Consultando os astros...';

  user.name = name;
  user.birthDate = date;
  user.birthTime = time;
  user.birthCity = city;
  user.timezone = timezone;
  user.context = document.getElementById('f-context')?.value?.trim() || '';
  user.firstTime = !localStorage.getItem(STORAGE_KEY);

  showLoading('Lendo seu mapa...', 'Consultando as posições planetárias do momento do seu nascimento', 0, () => {});

  try {
    const datetime = `${date} ${time}`;
    const url = `${BG_API}/v221006/hd-data?api_key=${BG_KEY}&date=${encodeURIComponent(datetime)}&timezone=${encodeURIComponent(timezone)}`;
    const res = await fetch(url);
    if (!res.ok) throw new Error(`API error: ${res.status}`);
    hdData = await res.json();
    if (!hdData || !hdData.Properties) throw new Error('Dados inválidos');

    const props = hdData.Properties;
    user.type = TR.types[props.Type?.id] || props.Type?.id || 'Desconhecido';
    user.authority = TR.authority[props.InnerAuthority?.id] || props.InnerAuthority?.id || 'Desconhecida';
    user.strategy = TR.strategy[props.Strategy?.id] || props.Strategy?.id || '';
    user.profile = props.Profile?.id || '';
    user.definition = TR.definition[props.Definition?.id] || props.Definition?.id || '';
    user.signature = TR.signature[props.Signature?.id] || props.Signature?.id || '';
    user.notSelf = TR.notself[props.NotSelfTheme?.id] || props.NotSelfTheme?.id || '';
    user.incarnationCross = props.IncarnationCross?.id || '';
    user.channels = (hdData.Channels || []).join(', ');
    user.definedCenters = (hdData.DefinedCenters || []).map(c => TR.centers[c] || c).join(', ');
    user.openCenters = (hdData.OpenCenters || []).map(c => TR.centers[c] || c).join(', ');
    user.hdData = hdData;

    localStorage.setItem(STORAGE_KEY, JSON.stringify(user));
    history = [];

    document.getElementById('loading-label').textContent = `${TR.typeEmoji[user.type] || '✦'} ${user.type}`;
    document.getElementById('loading-sub').textContent = `Perfil ${user.profile} · ${user.authority}`;
    setTimeout(() => initChat(), 2000);

  } catch(e) {
    console.error('HD API Error:', e);
    btn.disabled = false;
    btn.textContent = 'Revelar meu mapa ✦';
    showScreen('screen-onboarding');
    showError('Não consegui acessar seu mapa agora. Verifique se selecionou a cidade da lista e tente novamente.');
  }
}

